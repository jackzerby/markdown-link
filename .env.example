# Public URL used to build share links and claim URLs.
# For local development, you can switch this to http://localhost:3000.
APP_URL=https://mdshare.link

# Local development database. Swap to hosted Postgres for deployment.
DATABASE_URL=file:./dev.db

SESSION_SECRET=replace-me
API_KEY_PEPPER=replace-me

# Local filesystem storage is fine for dev.
# Set STORAGE_BACKEND=s3 and fill the S3 values before deployment.
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_PREFIX=publishes
STORAGE_S3_FORCE_PATH_STYLE=false

# Required for auth emails in production.
RESEND_API_KEY=
RESEND_FROM_EMAIL=auth@mdshare.link
RESEND_REPLY_TO=
RESEND_WEBHOOK_SECRET=

# Required for paid plans in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_HOBBY_MONTHLY=
STRIPE_CUSTOMER_PORTAL_CONFIGURATION_ID=

FREE_PUBLISH_TTL_SECONDS=604800
FREE_MAX_SITES=50
FREE_STORAGE_BYTES=10737418240
PAID_STORAGE_BYTES=107374182400

SUPPORT_EMAIL=support@mdshare.link
LOG_LEVEL=debug
