generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  FREE
  HOBBY
}

enum PlanStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum LoginPurpose {
  SIGN_IN
  CLAIM_SITE
  UPGRADE
}

enum SiteVisibility {
  PUBLIC
  UNLISTED
  PASSWORD
}

enum SourceType {
  MARKDOWN
}

enum SiteVersionStatus {
  PENDING
  LIVE
  FAILED
  DELETED
}

enum EmailTemplate {
  LOGIN_CODE
  CLAIM_LINK
  PLAN_CHANGED
  PAYMENT_ISSUE
}

enum EmailDeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum SupportRequestStatus {
  OPEN
  CLOSED
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  emailVerifiedAt  DateTime?
  name             String?
  stripeCustomerId String?          @unique
  planTier         PlanTier         @default(FREE)
  planStatus       PlanStatus       @default(NONE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  sessions         Session[]
  apiKeys          ApiKey[]
  ownedSites       Site[]           @relation("OwnedSites")
  siteVersions     SiteVersion[]
  handles          Handle[]
  subscription     Subscription?
  billingEvents    BillingEvent[]
  supportRequests  SupportRequest[]
  emailDeliveries  EmailDelivery[]
}

model EmailLoginCode {
  id           String        @id @default(cuid())
  email        String
  codeHash     String
  purpose      LoginPurpose  @default(SIGN_IN)
  redirectPath String?
  siteId       String?
  claimToken   String?
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int           @default(0)
  lastSentAt   DateTime      @default(now())
  createdAt    DateTime      @default(now())
  site         Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([email, purpose])
  @@index([expiresAt])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  prefix     String    @unique
  secretHash String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Handle {
  id        String   @id @default(cuid())
  userId    String
  slug      String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Site {
  id               String         @id @default(cuid())
  ownerUserId      String?
  slug             String         @unique
  title            String?
  description      String?
  currentVersionId String?        @unique
  visibility       SiteVisibility @default(PUBLIC)
  passwordHash     String?
  sourceType       SourceType     @default(MARKDOWN)
  expiresAt        DateTime?
  claimedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  owner            User?          @relation("OwnedSites", fields: [ownerUserId], references: [id], onDelete: SetNull)
  currentVersion   SiteVersion?   @relation("CurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions         SiteVersion[]  @relation("SiteVersions")
  claim            AnonymousClaim?
  loginCodes       EmailLoginCode[]

  @@index([ownerUserId])
  @@index([expiresAt])
}

model SiteVersion {
  id              String            @id @default(cuid())
  siteId          String
  status          SiteVersionStatus @default(PENDING)
  versionNumber   Int
  markdown        String
  manifestJson    Json?
  viewerJson      Json?
  storageKeyPrefix String?
  uploadTokenHash String?
  createdByUserId String?
  createdAt       DateTime          @default(now())
  finalizedAt     DateTime?
  site            Site              @relation("SiteVersions", fields: [siteId], references: [id], onDelete: Cascade)
  currentForSite  Site?             @relation("CurrentVersion")
  createdBy       User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  files           SiteFile[]

  @@unique([siteId, versionNumber])
}

model SiteFile {
  id            String      @id @default(cuid())
  siteVersionId String
  path          String
  size          Int
  contentType   String
  sha256        String?
  storageKey    String
  createdAt     DateTime    @default(now())
  siteVersion   SiteVersion @relation(fields: [siteVersionId], references: [id], onDelete: Cascade)

  @@unique([siteVersionId, path])
}

model AnonymousClaim {
  id              String    @id @default(cuid())
  siteId          String    @unique
  claimTokenHash  String
  expiresAt       DateTime
  claimedByUserId String?
  claimedAt       DateTime?
  createdAt       DateTime  @default(now())
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String     @id @default(cuid())
  userId               String     @unique
  stripeSubscriptionId String?    @unique
  stripePriceId        String?
  status               PlanStatus @default(NONE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BillingEvent {
  id            String   @id @default(cuid())
  userId        String?
  stripeEventId String   @unique
  type          String
  payloadJson   Json?
  processedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model EmailDelivery {
  id                String              @id @default(cuid())
  userId            String?
  email             String
  template          EmailTemplate
  providerMessageId String?
  status            EmailDeliveryStatus @default(QUEUED)
  metaJson          Json?
  createdAt         DateTime            @default(now())
  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model SupportRequest {
  id        String               @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    SupportRequestStatus @default(OPEN)
  createdAt DateTime             @default(now())
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}
